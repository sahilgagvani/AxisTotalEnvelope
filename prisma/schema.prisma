generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  QC_INSPECTOR
}

enum PanelStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String?
  pin       String?
  role      Role     @default(QC_INSPECTOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  name      String
  panels    Panel[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Panel {
  id              String      @id @default(cuid())
  panelIdentifier String
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  qrCodeUrl       String?
  status          PanelStatus @default(NOT_STARTED)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
